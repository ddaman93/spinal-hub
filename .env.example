# OpenWeather API
OPENWEATHER_API_KEY=

# Cloudflare R2 (S3 compatible)
R2_BUCKET=
R2_PUBLIC_BASE_URL=
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_KEY_PREFIX=
R2_MAX_RPS=2

# Database
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase (find in: supabase.com → project → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-this-in-production

# Admin moderation (set to a long random string; pass as X-Admin-Secret header)
ADMIN_SECRET=change-this-in-production

# OAuth — Google (find in: console.cloud.google.com → Credentials)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# OAuth — Facebook (find in: developers.facebook.com → your app → Settings → Basic)
EXPO_PUBLIC_FACEBOOK_APP_ID=
