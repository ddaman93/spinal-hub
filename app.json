{
  "expo": {
    "name": "Spinal Hub",
    "slug": "spinal-hub",
    "owner": "spinal-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spinalhub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,


    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spinalhub.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spinal Hub uses your location to find nearby accessible transport, care services, and spinal rehab centres.",
        "NSCalendarsUsageDescription": "Allow Spinal Hub to add your appointments to your calendar.",
        "NSUserNotificationsUsageDescription": "Get reminders for medications, pressure relief breaks, and appointments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#007AFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.spinalhub.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#007AFF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Spinal Hub to add appointments to your calendar."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}