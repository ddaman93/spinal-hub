{
  "expo": {
    "name": "Spinal Hub",
    "slug": "spinal-hub",
    "owner": "spinal-hub",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spinalhub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spinalhub.app",
      "buildNumber": "8",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spinal Hub uses your location to show local weather, nearby accessible transport, and carer services in your area.",
        "NSCalendarsUsageDescription": "Allow Spinal Hub to add your appointments to your calendar.",
        "NSUserNotificationsUsageDescription": "Get reminders for medications, pressure relief breaks, and appointments.",
        "ITSAppUsesNonExemptEncryption": false,
        "usesAppleSignIn": true,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1082274051218-jg2j75bptak19mkvd06vasemicbn543a"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#007AFF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.spinalhub.app",
      "versionCode": 7,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#007AFF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Spinal Hub to add appointments to your calendar."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "updates": {
      "url": "https://u.expo.dev/ef070dfa-d862-482a-88cd-3a2612939162"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ef070dfa-d862-482a-88cd-3a2612939162"
      }
    }
  }
}
