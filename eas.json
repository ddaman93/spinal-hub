{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "spinal-hub.onrender.com"
      },
      "ios": { "simulator": true, "image": "latest" },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "spinal-hub.onrender.com"
      },
      "ios": { "simulator": false, "image": "latest" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "spinal-hub.onrender.com"
      },
      "ios": { "simulator": false, "image": "latest" },
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {
      "ios": { "ascAppId": "6761002016" },
      "android": { "track": "internal" }
    }
  }
}
